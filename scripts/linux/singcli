#!/usr/bin/env sh

# Linux launcher for singcli.
# Install this file as /usr/bin/singcli, and keep the jar at /opt/singcli/singcli.jar.

JAR_PATH="/opt/singcli/singcli.jar"

if ! command -v java >/dev/null 2>&1; then
    echo "singcli: java was not found in PATH" >&2
    exit 127
fi

if [ ! -f "$JAR_PATH" ]; then
    echo "singcli: jar file was not found: $JAR_PATH" >&2
    exit 1
fi

exec java -jar "$JAR_PATH" "$@"
